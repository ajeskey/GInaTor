//- Visualization switcher sidebar with 17 viz types
aside.bg-base-100.w-72.min-h-full.flex.flex-col.border-r.border-base-300
  //- Sidebar header
  .p-4.border-b.border-base-300.flex.items-center.justify-between
    a.text-xl.font-bold.no-underline.text-base-content(href="/")
      span G
      span.text-primary Ina
      span Tor

  //- Visualization list
  nav.flex-1.overflow-y-auto.py-2
    ul#viz-list.menu.menu-sm.px-2
      li
        a.flex.items-center.gap-2(href="#" data-viz="timebloom")
          span 🌸
          span TimeBloom
      li
        a.flex.items-center.gap-2(href="#" data-viz="heatmap")
          span 🔥
          span Contributor Heatmap
      li
        a.flex.items-center.gap-2(href="#" data-viz="treemap")
          span 🗺️
          span File Hotspot Treemap
      li
        a.flex.items-center.gap-2(href="#" data-viz="sunburst")
          span ☀️
          span Code Ownership Sunburst
      li
        a.flex.items-center.gap-2(href="#" data-viz="branches")
          span 🌿
          span Branch/Merge Graph
      li
        a.flex.items-center.gap-2(href="#" data-viz="pulse")
          span 💓
          span Commit Pulse
      li
        a.flex.items-center.gap-2(href="#" data-viz="impact")
          span 💥
          span Impact Visualization
      li
        a.flex.items-center.gap-2(href="#" data-viz="collaboration")
          span 🤝
          span Collaboration Network
      li
        a.flex.items-center.gap-2(href="#" data-viz="filetypes")
          span 📊
          span File Type Distribution
      li
        a.flex.items-center.gap-2(href="#" data-viz="activity-matrix")
          span 📅
          span Activity Matrix
      li
        a.flex.items-center.gap-2(href="#" data-viz="bubblemap")
          span 🫧
          span Bubble Map
      li
        a.flex.items-center.gap-2(href="#" data-viz="complexity")
          span 📈
          span Code Complexity Trend
      li
        a.flex.items-center.gap-2(href="#" data-viz="pr-flow")
          span 🔀
          span PR/MR Review Flow
      li
        a.flex.items-center.gap-2(href="#" data-viz="bus-factor")
          span 🚌
          span Bus Factor
      li
        a.flex.items-center.gap-2(href="#" data-viz="stale-files")
          span 🕸️
          span Stale Files
      li
        a.flex.items-center.gap-2(href="#" data-viz="city-block")
          span 🏙️
          span City Block
      li
        a.flex.items-center.gap-2(href="#" data-viz="genome")
          span 🧬
          span Genome Sequence

  //- Admin panel link at bottom
  .p-4.border-t.border-base-300
    a.btn.btn-ghost.btn-sm.w-full.justify-start.gap-2(href="/admin")
      svg.w-4.h-4(xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor")
