//- Application header: repo selector, stats bar, theme toggle, compare toggle, user menu
.navbar.bg-base-100.border-b.border-base-300.px-4.gap-2
  //- Mobile menu button
  .flex-none(class="lg:hidden")
    label.btn.btn-square.btn-ghost(for="sidebar-drawer")
      svg.w-6.h-6(xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor")
        path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16")

  //- Repo selector (left)
  .flex-none
    .form-control
      select#repo-select.select.select-bordered.select-sm
        option(value="" disabled selected) Loading repos...

  //- Stats bar (center)
  .flex-1.justify-center.gap-4.text-sm.hidden(class="md:flex")#stats-bar
    .flex.items-center.gap-1
      span.text-base-content.opacity-60 Contributors
      span.font-semibold#stat-contributors --
    .divider.divider-horizontal.mx-0
    .flex.items-center.gap-1
      span.text-base-content.opacity-60 Files
      span.font-semibold#stat-files --
    .divider.divider-horizontal.mx-0.hidden(class="lg:flex")
    .flex.items-center.gap-1.hidden(class="lg:flex")
      span.text-base-content.opacity-60 First
      span.font-semibold#stat-first-date --
    .divider.divider-horizontal.mx-0.hidden(class="lg:flex")
    .flex.items-center.gap-1.hidden(class="lg:flex")
      span.text-base-content.opacity-60 Last
      span.font-semibold#stat-last-date --
    .divider.divider-horizontal.mx-0
    .flex.items-center.gap-1
      span.text-base-content.opacity-60 Commits
      span.font-semibold#stat-commits --

  //- Right controls: theme toggle, compare toggle, user menu
  .flex-none.flex.items-center.gap-1
    //- Theme toggle
    button#theme-toggle.btn.btn-ghost.btn-sm.btn-square(title="Toggle theme")
      svg#theme-icon-sun.w-5.h-5(xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor")
        path(d="M5.64,17l-.71.71a1,1,0,0,0,0,1.41,1,1,0,0,0,1.41,0l.71-.71A1,1,0,0,0,5.64,17ZM5,12a1,1,0,0,0-1-1H3a1,1,0,0,0,0,2H4A1,1,0,0,0,5,12Zm7-7a1,1,0,0,0,1-1V3a1,1,0,0,0-2,0V4A1,1,0,0,0,12,5ZM5.64,7.05a1,1,0,0,0,.7.29,1,1,0,0,0,.71-.29,1,1,0,0,0,0-1.41l-.71-.71A1,1,0,0,0,4.93,6.34Zm12,.29a1,1,0,0,0,.7-.29l.71-.71a1,1,0,1,0-1.41-1.41L17,5.64a1,1,0,0,0,0,1.41A1,1,0,0,0,17.66,7.34ZM21,11H20a1,1,0,0,0,0,2h1a1,1,0,0,0,0-2Zm-9,8a1,1,0,0,0-1,1v1a1,1,0,0,0,2,0V20A1,1,0,0,0,12,19ZM18.36,17A1,1,0,0,0,17,18.36l.71.71a1,1,0,0,0,1.41,0,1,1,0,0,0,0-1.41ZM12,6.5A5.5,5.5,0,1,0,17.5,12,5.51,5.51,0,0,0,12,6.5Zm0,9A3.5,3.5,0,1,1,15.5,12,3.5,3.5,0,0,1,12,15.5Z")

    //- Compare toggle
    button#compare-toggle.btn.btn-ghost.btn-sm.btn-square(title="Compare Mode")
      svg.w-5.h-5(xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor")
        path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7")

    //- User menu
    .dropdown.dropdown-end
      label.btn.btn-ghost.btn-sm.btn-square(tabindex="0")
        svg.w-5.h-5(xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor")
          path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z")
      ul.dropdown-content.menu.bg-base-100.rounded-box.shadow-lg.w-52.p-2.mt-2.z-50(tabindex="0")
        li
          a(href="/admin")
            svg.w-4.h-4(xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor")
              path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z")
              path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z")
            | Admin Panel
        .divider.my-0
        li
          form(method="POST" action="/auth/logout")
            button.w-full.text-left(type="submit") Logout
