extends ../layout

block head
  title GInaTor - Diff Viewer

block content
  .flex.flex-col.gap-4
    //- Diff header with file info and mode toggle
    .flex.flex-wrap.items-center.justify-between.gap-4.bg-base-100.rounded-box.p-4.shadow
      .flex.items-center.gap-3
        a.btn.btn-ghost.btn-sm(href="/dashboard") ← Back
        h2#diff-file-path.text-lg.font-semibold --
      .join
        button#diff-mode-split.btn.btn-sm.join-item.btn-active(data-mode="split") Side by Side
        button#diff-mode-unified.btn.btn-sm.join-item(data-mode="unified") Unified

    //- Diff content area
    #diff-content.bg-base-100.rounded-box.shadow.min-h-96.p-4
      .flex.items-center.justify-center.h-64.text-base-content.opacity-60
        p Select a file from a visualization to view its diff history.

block scripts
  script(src="/js/diff/DiffViewer.js" type="module")
