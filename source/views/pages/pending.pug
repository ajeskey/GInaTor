doctype html
html(lang="en" data-theme="light")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title GInaTor - Pending Approval
    link(href="https://cdn.jsdelivr.net/npm/daisyui@4/dist/full.min.css" rel="stylesheet")
    script(src="https://cdn.tailwindcss.com")
  body.bg-base-200.min-h-screen.flex.items-center.justify-center
    .card.w-full.max-w-md.bg-base-100.shadow-xl
      .card-body.text-center
        .text-6xl.mb-4 ⏳
        h2.card-title.text-2xl.font-bold.mb-4.justify-center Pending Approval
        p.text-base-content.opacity-70.mb-6
          | Your account has been created but is awaiting admin approval.
          | You'll be able to access GInaTor once an administrator approves your account.
        .divider
        form(method="POST" action="/auth/logout")
          button.btn.btn-outline.btn-sm(type="submit") Logout
