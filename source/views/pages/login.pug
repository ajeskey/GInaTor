doctype html
html(lang="en" data-theme="light")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title GInaTor - Login
    link(href="https://cdn.jsdelivr.net/npm/daisyui@4/dist/full.min.css" rel="stylesheet")
    script(src="https://cdn.tailwindcss.com")
  body.bg-base-200.min-h-screen.flex.items-center.justify-center
    .card.w-full.max-w-md.bg-base-100.shadow-xl
      .card-body
        h2.card-title.text-2xl.font-bold.mb-4.justify-center GInaTor
        p.text-center.text-base-content.opacity-70.mb-6 Sign in to your account

        #login-error.alert.alert-error.hidden.mb-4
          span#login-error-msg

        form#login-form(method="POST" action="/auth/login")
          .form-control.mb-4
            label.label
              span.label-text Email
            input.input.input-bordered.w-full(type="email" name="email" required placeholder="you@example.com")
          .form-control.mb-6
            label.label
              span.label-text Password
            input.input.input-bordered.w-full(type="password" name="password" required placeholder="••••••••")
          button.btn.btn-primary.w-full(type="submit") Sign In

        .divider OR

        p.text-center.text-sm
          | Don't have an account?&nbsp;
          a.link.link-primary(href="/register") Register

    script.
      (function() {
        var form = document.getElementById('login-form');
        form.addEventListener('submit', function(e) {
          e.preventDefault();
          var data = new FormData(form);
          fetch('/auth/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              email: data.get('email'),
              password: data.get('password')
            }),
            credentials: 'same-origin'
          }).then(function(res) {
            if (res.ok) {
              window.location.href = '/dashboard';
            } else {
              return res.json().then(function(body) {
                var errEl = document.getElementById('login-error');
                var msgEl = document.getElementById('login-error-msg');
                errEl.classList.remove('hidden');
                msgEl.textContent = body.error || 'Login failed';
              });
            }
          }).catch(function() {
            var errEl = document.getElementById('login-error');
            var msgEl = document.getElementById('login-error-msg');
            errEl.classList.remove('hidden');
            msgEl.textContent = 'Network error. Please try again.';
          });
        });
      })();
