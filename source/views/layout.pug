doctype html
html(lang="en" data-theme="light")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title GInaTor - #{title || 'Git Visualization'}
    link(href="https://cdn.jsdelivr.net/npm/daisyui@4/dist/full.min.css" rel="stylesheet")
    script(src="https://cdn.tailwindcss.com")
    block head
  body.bg-base-200.min-h-screen.flex
    //- Sidebar
    include partials/sidebar

    //- Main wrapper (header + content + footer)
    .flex-1.flex.flex-col.min-h-screen.overflow-x-hidden
      //- Header
      include partials/header

      //- Timeline scrubber
      include partials/timeline-scrubber

      //- Main content area
      main.flex-1.p-4
        block content

      //- Footer
      include partials/footer

    //- Theme toggle script
    script(src="/js/theme/ThemeToggle.js" type="module")
    //- Repo selector script
    script(src="/js/components/RepoSelector.js" type="module")
    //- Stats bar script
    script(src="/js/components/StatsBar.js" type="module")
    block scripts
