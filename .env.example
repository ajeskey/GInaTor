# GInaTor Environment Variables

# Session secret for express-session (use a strong random string)
SESSION_SECRET=your-session-secret-here

# AES-256 encryption key for stored credentials (32-byte hex string)
ENCRYPTION_KEY=your-256-bit-hex-encryption-key-here

# DynamoDB configuration
# Set DYNAMODB_ENDPOINT for local development (e.g., http://localhost:8000)
# Leave unset to use AWS DynamoDB in production
DYNAMODB_ENDPOINT=http://localhost:8000

# AWS configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# Server configuration
PORT=3000
NODE_ENV=development

# CORS allowed origin
CORS_ORIGIN=http://localhost:3000

# GitHub OAuth App (for "Connect GitHub" flow)
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret
